{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "singleQuote": true,
  "jsxSingleQuote": true,
  "semi": false,
  "endOfLine": "lf",
  "printWidth": 100,
  "trailingComma": "all",
  "ignorePatterns": [
    "dist/**",
    "node_modules/**",
    "pnpm-lock.yaml",
    "package-lock.json",
    "yarn.lock"
  ]
}
