{
  "name": "blog",
  "version": "2.0.0",
  "private": true,
  "homepage": "https://xSeek-Neo.github.io/docs/",
  "type": "module",
  "scripts": {
    "dev": "pnpm run clean:cache && rspress dev",
    "build": "rspress build",
    "deploy": "bash scripts/deploy.sh",
    "format": "oxfmt .",
    "format:check": "oxfmt . --check",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "preview": "rspress preview",
    "clean:cache": "rm -rf node_modules/.cache/rspack node_modules/.cache/rspack-blog node_modules/.rspress",
    "prepare": "husky"
  },
  "dependencies": {
    "@rspress/core": "^2.0.14",
    "@rstack-dev/doc-ui": "^1.14.5"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.0",
    "@commitlint/config-conventional": "^21.2.0",
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "husky": "^9.1.7",
    "oxfmt": "^0.57.0",
    "oxlint": "^1.72.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "engines": {
    "node": ">=24"
  }
}
